# ═══════════════════════════════════════════════════════════════
#  .GITIGNORE
#  Sistema de Gestión de Inventario — Tienda de Ropa Local
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
#  NODE.JS — dependencias
#  Se regeneran automáticamente con npm ci
#  durante el docker compose up --build
# ─────────────────────────────────────────────
node_modules/
apps/backend/node_modules/
apps/frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────
#  DATOS DE RUNTIME
# ─────────────────────────────────────────────
apps/backend/data/
*.json.bak

# ─────────────────────────────────────────────
#  VARIABLES DE ENTORNO Y SECRETOS
# ─────────────────────────────────────────────
.env
.env.local
.env.production
.env*.local
*.pem
*.key

# ─────────────────────────────────────────────
#  SONARQUBE — archivos locales del scanner
# ─────────────────────────────────────────────
.sonar/
.scannerwork/
coverage/

# ─────────────────────────────────────────────
#  SERVERLESS FRAMEWORK — artefactos de despliegue
#  Contienen ZIPs generados y variables de entorno
#  (incluye secretos como JWT_SECRET) — nunca al repo.
# ─────────────────────────────────────────────
.serverless/

# ─────────────────────────────────────────────
#  DOCKER — archivos temporales
# ─────────────────────────────────────────────
.docker/

# ─────────────────────────────────────────────
#  SISTEMA OPERATIVO
# ─────────────────────────────────────────────

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.Trash-*

# ─────────────────────────────────────────────
#  EDITORES
# ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
*.code-workspace

# JetBrains
.idea/
*.iml

# ─────────────────────────────────────────────
#  LOGS LOCALES
# ─────────────────────────────────────────────
logs/
*.log
